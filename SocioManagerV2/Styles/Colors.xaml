<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Primary Colors -->
    <Color x:Key="PrimaryColor">#2C3E50</Color>
    <Color x:Key="PrimaryDarkColor">#1A252F</Color>
    <Color x:Key="PrimaryLightColor">#34495E</Color>
    
    <!-- Accent Colors -->
    <Color x:Key="AccentColor">#3498DB</Color>
    <Color x:Key="AccentHoverColor">#2980B9</Color>
    <Color x:Key="AccentPressedColor">#21618C</Color>
    
    <!-- Success Colors -->
    <Color x:Key="SuccessColor">#27AE60</Color>
    <Color x:Key="SuccessHoverColor">#229954</Color>
    <Color x:Key="SuccessPressedColor">#1E8449</Color>
    
    <!-- Danger Colors -->
    <Color x:Key="DangerColor">#E74C3C</Color>
    <Color x:Key="DangerHoverColor">#C0392B</Color>
    <Color x:Key="DangerPressedColor">#A93226</Color>
    
    <!-- Warning Colors -->
    <Color x:Key="WarningColor">#F39C12</Color>
    <Color x:Key="WarningHoverColor">#D68910</Color>
    <Color x:Key="WarningPressedColor">#B9770E</Color>
    
    <!-- Neutral Colors -->
    <Color x:Key="NeutralColor">#95A5A6</Color>
    <Color x:Key="NeutralHoverColor">#7F8C8D</Color>
    <Color x:Key="NeutralPressedColor">#707B7C</Color>
    
    <!-- Background Colors -->
    <Color x:Key="BackgroundColor">#ECF0F1</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="CardColor">#FFFFFF</Color>
    <Color x:Key="HoverBackgroundColor">#F8F9FA</Color>
    
    <!-- Text Colors -->
    <Color x:Key="TextPrimaryColor">#2C3E50</Color>
    <Color x:Key="TextSecondaryColor">#7F8C8D</Color>
    <Color x:Key="TextOnPrimaryColor">#FFFFFF</Color>
    
    <!-- Border Colors -->
    <Color x:Key="BorderColor">#BDC3C7</Color>
    <Color x:Key="BorderLightColor">#D5DBDB</Color>
    <Color x:Key="FocusBorderColor">#3498DB</Color>
    
    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}"/>
    
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}"/>
    
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="SuccessHoverBrush" Color="{StaticResource SuccessHoverColor}"/>
    <SolidColorBrush x:Key="SuccessPressedBrush" Color="{StaticResource SuccessPressedColor}"/>
    
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="DangerHoverBrush" Color="{StaticResource DangerHoverColor}"/>
    <SolidColorBrush x:Key="DangerPressedBrush" Color="{StaticResource DangerPressedColor}"/>
    
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="WarningHoverBrush" Color="{StaticResource WarningHoverColor}"/>
    <SolidColorBrush x:Key="WarningPressedBrush" Color="{StaticResource WarningPressedColor}"/>
    
    <SolidColorBrush x:Key="NeutralBrush" Color="{StaticResource NeutralColor}"/>
    <SolidColorBrush x:Key="NeutralHoverBrush" Color="{StaticResource NeutralHoverColor}"/>
    <SolidColorBrush x:Key="NeutralPressedBrush" Color="{StaticResource NeutralPressedColor}"/>
    
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}"/>
    <SolidColorBrush x:Key="HoverBackgroundBrush" Color="{StaticResource HoverBackgroundColor}"/>
    
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="{StaticResource TextOnPrimaryColor}"/>
    
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderLightBrush" Color="{StaticResource BorderLightColor}"/>
    <SolidColorBrush x:Key="FocusBorderBrush" Color="{StaticResource FocusBorderColor}"/>

</ResourceDictionary>
