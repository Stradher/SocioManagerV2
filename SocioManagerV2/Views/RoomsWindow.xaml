<Window x:Class="SocioManagerV2.Views.RoomsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SocioManagerV2.ViewModels"
        Title="Rooms Manager" 
        Height="540" Width="850"
        Style="{StaticResource ModernWindowStyle}"
        WindowStartupLocation="CenterOwner">

    <Window.DataContext>
        <vm:RoomsViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="20">
            <TextBlock Text="🚪 Manage Rooms" 
                       FontSize="24" FontWeight="Bold" 
                       Foreground="{StaticResource TextOnPrimaryBrush}"/>
        </Border>

        <!-- Tab Control -->
        <TabControl Grid.Row="1" Margin="10">
            <!-- Rooms Tab -->
            <TabItem Header="Rooms">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource BackgroundBrush}" Padding="20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Room Name" Style="{StaticResource LabelTextBlockStyle}"/>
                                <TextBox Text="{Binding RoomName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="10,0,10,0">
                                <TextBlock Text="Capacity" Style="{StaticResource LabelTextBlockStyle}"/>
                                <TextBox Text="{Binding RoomCapacity, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Bottom" Orientation="Horizontal" Margin="10,0,0,0">
                                <Button Content="➕ Add Room" 
                                        Command="{Binding AddRoomCommand}" 
                                        Style="{StaticResource SuccessButtonStyle}"
                                        Margin="0,0,10,0" MinHeight="36" Padding="15,5"/>

                                <Button Content="🗑️ Delete Selected" 
                                        Command="{Binding DeleteRoomCommand}" 
                                        Style="{StaticResource DangerButtonStyle}" MinHeight="36" Padding="15,5"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Background="{StaticResource BackgroundBrush}" Padding="20,0,20,20">
                        <DataGrid ItemsSource="{Binding Rooms}" 
                                  SelectedItem="{Binding SelectedRoom, Mode=TwoWay}"
                                  Style="{StaticResource ModernDataGridStyle}"
                                  ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeaderStyle}"
                                  RowStyle="{StaticResource ModernDataGridRowStyle}"
                                  CellStyle="{StaticResource ModernDataGridCellStyle}"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                                <DataGridTextColumn Header="Room Name" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="Max Capacity" Binding="{Binding MaxCapacity}" Width="150"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Bookings Tab -->
            <TabItem Header="Bookings">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource BackgroundBrush}" Padding="20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Room" Style="{StaticResource LabelTextBlockStyle}"/>
                                <ComboBox ItemsSource="{Binding Rooms}" 
                                          SelectedItem="{Binding SelectedBookingRoom}" 
                                          DisplayMemberPath="Name" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="10,0,10,0">
                                <TextBlock Text="Booker" Style="{StaticResource LabelTextBlockStyle}"/>
                                <ComboBox ItemsSource="{Binding Socios}" 
                                          SelectedItem="{Binding SelectedBooker}" 
                                          DisplayMemberPath="Nombre" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="10,0,10,0">
                                <TextBlock Text="Duration (Mins)" Style="{StaticResource LabelTextBlockStyle}"/>
                                <TextBox Text="{Binding BookingDuration, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3" VerticalAlignment="Bottom" Orientation="Horizontal" Margin="10,0,0,0">
                                <Button Content="📅 Book Room" 
                                        Command="{Binding AddBookingCommand}" 
                                        Style="{StaticResource SuccessButtonStyle}"
                                        Margin="0,0,10,0" MinHeight="36" Padding="15,5"/>

                                <Button Content="🗑️ Cancel Booking" 
                                        Command="{Binding DeleteBookingCommand}" 
                                        Style="{StaticResource DangerButtonStyle}" MinHeight="36" Padding="15,5"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Background="{StaticResource BackgroundBrush}" Padding="20,0,20,20">
                        <DataGrid ItemsSource="{Binding Bookings}" 
                                  SelectedItem="{Binding SelectedBooking, Mode=TwoWay}"
                                  Style="{StaticResource ModernDataGridStyle}"
                                  ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeaderStyle}"
                                  RowStyle="{StaticResource ModernDataGridRowStyle}"
                                  CellStyle="{StaticResource ModernDataGridCellStyle}"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Room" Binding="{Binding Room.Name}" Width="*"/>
                                <DataGridTextColumn Header="Booker" Binding="{Binding Booker.Nombre}" Width="*"/>
                                <DataGridTextColumn Header="Date/Time" Binding="{Binding BookingDate, StringFormat=\{0:dd/MM/yyyy HH:mm\}}" Width="150"/>
                                <DataGridTextColumn Header="Duration" Binding="{Binding DurationMinutes, StringFormat=\{0\} mins}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

    </Grid>
</Window>