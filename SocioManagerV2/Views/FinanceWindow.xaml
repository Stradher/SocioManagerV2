<Window x:Class="SocioManagerV2.Views.FinanceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SocioManagerV2.ViewModels"
        xmlns:converters="clr-namespace:SocioManagerV2.Converters"
        Title="Finance Manager" 
        Height="650" Width="900"
        Style="{StaticResource ModernWindowStyle}"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <converters:InvertBoolConverter x:Key="InvertBoolConverter" />
    </Window.Resources>

    <Window.DataContext>
        <vm:FinanceViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="💰 Finance Manager" 
                           FontSize="24" FontWeight="Bold" 
                           Foreground="{StaticResource TextOnPrimaryBrush}"/>

                <TextBlock Grid.Column="1" Text="{Binding CurrentBalance, StringFormat='Current Balance: $ {0:N2}'}" 
                           FontSize="22" FontWeight="SemiBold" 
                           Foreground="{StaticResource TextOnPrimaryBrush}" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Tab Control -->
        <TabControl Grid.Row="1" Margin="10">
            <!-- Treasury Tab -->
            <TabItem Header="Treasury">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource BackgroundBrush}" Padding="20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Type" Style="{StaticResource LabelTextBlockStyle}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <RadioButton Content="Income" IsChecked="{Binding IsIncome}" Margin="0,0,15,0"/>
                                    <RadioButton Content="Expense"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="10,0,10,0">
                                <TextBlock Text="Concept" Style="{StaticResource LabelTextBlockStyle}"/>
                                <TextBox Text="{Binding TransactionConcept, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="10,0,10,0">
                                <TextBlock Text="Amount" Style="{StaticResource LabelTextBlockStyle}"/>
                                <TextBox Text="{Binding TransactionAmount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3" Margin="10,0,0,0">
                                <TextBlock Text="Date" Style="{StaticResource LabelTextBlockStyle}"/>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                    <DatePicker SelectedDate="{Binding TransactionDate}" Style="{StaticResource ModernDatePickerStyle}" Margin="0,0,10,0" Width="120"/>
                                    <Button Content="➕ Add" 
                                            Command="{Binding AddTransactionCommand}" 
                                            Style="{StaticResource SuccessButtonStyle}" MinHeight="36" Padding="15,4"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Background="{StaticResource BackgroundBrush}" Padding="20,0,20,20">
                        <DataGrid ItemsSource="{Binding TreasuryTransactions}" 
                                  Style="{StaticResource ModernDataGridStyle}"
                                  ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeaderStyle}"
                                  RowStyle="{StaticResource ModernDataGridRowStyle}"
                                  CellStyle="{StaticResource ModernDataGridCellStyle}"
                                  IsReadOnly="True" AutoGenerateColumns="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=\{0:dd/MM/yyyy\}}" Width="100"/>
                                <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="100"/>
                                <DataGridTextColumn Header="Concept" Binding="{Binding Concept}" Width="*"/>
                                <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=\{0:N2\}}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Subscriptions Tab -->
            <TabItem Header="Subscriptions">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource BackgroundBrush}" Padding="20">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Select Month:" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Margin="0,0,15,0"/>
                            <ComboBox ItemsSource="{Binding AvailableMonths}" 
                                      SelectedItem="{Binding SelectedMonth}" 
                                      Width="150" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Background="{StaticResource BackgroundBrush}" Padding="20,0,20,20">
                        <DataGrid ItemsSource="{Binding MemberSubscriptions}" 
                                  Style="{StaticResource ModernDataGridStyle}"
                                  ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeaderStyle}"
                                  RowStyle="{StaticResource ModernDataGridRowStyle}"
                                  CellStyle="{StaticResource ModernDataGridCellStyle}"
                                  IsReadOnly="True" AutoGenerateColumns="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Socio ID" Binding="{Binding SocioId}" Width="80"/>
                                <DataGridTextColumn Header="Member Name" Binding="{Binding MemberName}" Width="*"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="120"/>
                                <DataGridTemplateColumn Header="Action" Width="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding ActionText}" 
                                                    Command="{Binding DataContext.TogglePaymentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource PrimaryButtonStyle}" 
                                                    MinHeight="30" Padding="10,0" Margin="0,2,0,2"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

    </Grid>
</Window>