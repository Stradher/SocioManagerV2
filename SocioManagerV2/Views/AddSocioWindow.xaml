<Window x:Class="SocioManagerV2.Views.AddSocioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SocioManagerV2.ViewModels"
        xmlns:converters="clr-namespace:SocioManagerV2.Converters"
        Title="Add New Socio"
        Height="600" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <converters:IntToBoolConverter x:Key="IntToBoolConverter"/>
    </Window.Resources>

    <Window.DataContext>
        <vm:AddSocioViewModel/>
    </Window.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="New Socio Details" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel DataContext="{Binding NewSocio}">
                <TextBlock Text="Nombre *" FontWeight="Bold" Margin="0,5,0,2"/>
                <TextBox Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}" Padding="5"/>

                <TextBlock Text="Apellido 1" FontWeight="Bold" Margin="0,10,0,2"/>
                <TextBox Text="{Binding Apellido1, UpdateSourceTrigger=PropertyChanged}" Padding="5"/>

                <TextBlock Text="Apellido 2" FontWeight="Bold" Margin="0,10,0,2"/>
                <TextBox Text="{Binding Apellido2, UpdateSourceTrigger=PropertyChanged}" Padding="5"/>

                <TextBlock Text="DNI" FontWeight="Bold" Margin="0,10,0,2"/>
                <TextBox Text="{Binding Dni, UpdateSourceTrigger=PropertyChanged}" Padding="5"/>

                <TextBlock Text="Alta" FontWeight="Bold" Margin="0,10,0,2"/>
                <TextBox Text="{Binding Alta, UpdateSourceTrigger=PropertyChanged}" Padding="5"/>

                <TextBlock Text="Fecha de Nacimiento" FontWeight="Bold" Margin="0,10,0,2"/>
                <DatePicker SelectedDate="{Binding FechaNacimiento, UpdateSourceTrigger=PropertyChanged}" Padding="5"/>

                <TextBlock Text="Número de Socio" FontWeight="Bold" Margin="0,10,0,2"/>
                <TextBox Text="{Binding NumeroDeSocio, UpdateSourceTrigger=PropertyChanged}" Padding="5"/>

                <TextBlock Text="Número de Teléfono" FontWeight="Bold" Margin="0,10,0,2"/>
                <TextBox Text="{Binding NumeroDeTelefono, UpdateSourceTrigger=PropertyChanged}" Padding="5"/>

                <TextBlock Text="Correo Electrónico" FontWeight="Bold" Margin="0,10,0,2"/>
                <TextBox Text="{Binding CorreoElectronico, UpdateSourceTrigger=PropertyChanged}" Padding="5"/>

                <TextBlock Text="Dirección Postal" FontWeight="Bold" Margin="0,10,0,2"/>
                <TextBox Text="{Binding DireccionPostal, UpdateSourceTrigger=PropertyChanged}" 
                         Padding="5" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>

                <TextBlock Text="Fecha de Alta" FontWeight="Bold" Margin="0,10,0,2"/>
                <DatePicker SelectedDate="{Binding FechaDeAlta, UpdateSourceTrigger=PropertyChanged}" Padding="5"/>

                <TextBlock Text="Fecha de Baja" FontWeight="Bold" Margin="0,10,0,2"/>
                <DatePicker SelectedDate="{Binding FechaDeBaja, UpdateSourceTrigger=PropertyChanged}" Padding="5"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Save" 
                    Command="{Binding SaveCommand}"
                    Background="#4CAF50" 
                    Foreground="White"
                    Padding="20,10"
                    FontWeight="Bold"
                    MinWidth="100"
                    Margin="0,0,10,0"/>

            <Button Content="Cancel" 
                    Command="{Binding CancelCommand}"
                    Background="#9E9E9E" 
                    Foreground="White"
                    Padding="20,10"
                    FontWeight="Bold"
                    MinWidth="100"/>
        </StackPanel>
    </Grid>
</Window>
