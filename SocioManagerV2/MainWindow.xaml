<Window x:Class="SocioManagerV2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SocioManagerV2.ViewModels"
        Title="Socio Manager V2"
        Height="700" Width="1400"
        Style="{StaticResource ModernWindowStyle}">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="30,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Socio Manager V2" 
                               FontSize="28" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource TextOnPrimaryBrush}"/>
                    <TextBlock Text="Member Management System" 
                               FontSize="14" 
                               Foreground="{StaticResource TextOnPrimaryBrush}"
                               Opacity="0.8"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Action Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="🎲 Board Games" 
                            Command="{Binding OpenBoardGamesCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0,0,15,0"/>

                    <Button Content="🔍 Search Members"
                            Command="{Binding SearchCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0,0,15,0"/>

                    <Button Content="➕ Add New Member" 
                            Command="{Binding AddCommand}"
                            Style="{StaticResource SuccessButtonStyle}"
                            Margin="0,0,15,0"/>

                    <Button Content="🗑️ Delete Selected" 
                            Command="{Binding DeleteCommand}"
                            Style="{StaticResource DangerButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content Section -->
        <Border Grid.Row="1" Background="{StaticResource BackgroundBrush}" Padding="30">
            <Border Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" 
                               Text="Members Directory" 
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               Margin="0,0,0,20"/>

                    <!-- DataGrid -->
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Socios}"
                              SelectedItem="{Binding SelectedSocio, Mode=TwoWay}"
                              Style="{StaticResource ModernDataGridStyle}"
                              ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeaderStyle}"
                              RowStyle="{StaticResource ModernDataGridRowStyle}"
                              CellStyle="{StaticResource ModernDataGridCellStyle}"
                              IsReadOnly="True"
                              MouseDoubleClick="DataGrid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding Nombre}" Width="*"/>
                            <DataGridTextColumn Header="First Surname" Binding="{Binding Apellido1}" Width="*"/>
                            <DataGridTextColumn Header="Second Surname" Binding="{Binding Apellido2}" Width="*"/>
                            <DataGridTextColumn Header="ID Number" Binding="{Binding Dni}" Width="120"/>
                            <DataGridTextColumn Header="Member #" Binding="{Binding NumeroDeSocio}" Width="100"/>
                            <DataGridTextColumn Header="Phone" Binding="{Binding NumeroDeTelefono}" Width="130"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>
